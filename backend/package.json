{
  "name": "smartpos-backend",
  "version": "1.0.0",
  "description": "SmartPOS Crypto Payment Platform Backend",
  "private": true,
  "license": "UNLICENSED",
  "author": "InfoJames Merchant Solutions",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate --schema ../database/schema/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../database/schema/schema.prisma",
    "prisma:push": "prisma db push --schema ../database/schema/schema.prisma",
    "prisma:studio": "prisma studio --schema ../database/schema/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/rate-limit": "^10.1.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/websocket": "^11.0.2",
    "@prisma/client": "^6.10.1",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.80.2",
    "dayjs": "^1.11.13",
    "decimal.js": "^10.5.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "pino": "^9.4.0",
    "pino-pretty": "^13.0.0",
    "stripe": "^22.3.1",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "prisma": "^6.10.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
