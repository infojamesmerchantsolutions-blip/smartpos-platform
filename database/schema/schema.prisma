// ==========================================
// MODELS
// ==========================================

// ---------- AUTHENTICATION ----------
model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  phone              String?             @unique
  passwordHash       String?
  firstName          String
  lastName           String
  displayName        String?
  avatar             String?
  role               UserRole            @default(VIEWER)
  status             UserStatus?         // might need to define UserStatus; I'll add enum UserStatus
  lastLoginAt        DateTime?
  lastLoginIP        String?
  isActive           Boolean             @default(true)
  isVerified         Boolean             @default(false)
  isMFAEnabled       Boolean             @default(false)
  mfaSecret          String?
  backupCodes        Json?               // encrypted backup codes
  passwordResetToken String?             @unique
  passwordResetExpires DateTime?
  emailVerifyToken   String?             @unique
  emailVerifyExpires DateTime?
  deletedAt          DateTime?

  // Relations
  merchantId         String?
  merchant           Merchant?           @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  refreshTokens      RefreshToken[]
  sessions           Session[]
  loginHistory       LoginHistory[]
  oauthAccounts      OAuthAccount[]
  apiKeys            ApiKey[]
  userPermissions    UserPermission[]
  auditLogs          AuditLog[]          @relation("UserAuditLog")
  notifications      Notification[]      @relation("UserNotification")
  activityLogs       ActivityLog[]       @relation("UserActivity")
  employee           Employee?           @relation(fields: [employeeId], references: [id]) // if user is also employee
  employeeId         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([email])
  @@index([phone])
  @@index([merchantId])
  @@index([role])
  @@index([status])
  @@index([deletedAt])
}

model RefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  replacedBy  String?  @unique // token that replaced this one
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  deviceInfo  Json?
  isActive    Boolean  @default(true)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model PasswordReset {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  usedAt      DateTime?
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerification {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model ApiKey {
  id          String        @id @default(cuid())
  name        String
  keyHash     String        @unique // hashed key
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchantId  String?       // can be scoped to merchant
  merchant    Merchant?     @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  permissions Json          // list of permissions
  status      ApiKeyStatus  @default(ACTIVE)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  revokedAt   DateTime?
  usage       ApiKeyUsage[]

  @@index([userId])
  @@index([merchantId])
  @@index([keyHash])
  @@index([status])
}

model ApiKeyUsage {
  id          String   @id @default(cuid())
  apiKeyId    String
  apiKey      ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  endpoint    String
  method      String
  ipAddress   String?
  userAgent   String?
  responseStatus Int
  responseTime Int // ms
  createdAt   DateTime @default(now())

  @@index([apiKeyId])
  @@index([createdAt(sort: Desc)])
}

model Permission {
  id          String         @id @default(cuid())
  name        String         @unique // e.g., "transactions:read"
  description String?
  resource    String         // e.g., "transactions"
  action      PermissionType // e.g., READ
  roles       RolePermission[]
  userPermissions UserPermission[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([name])
  @@index([resource, action])
}

model Role {
  id          String         @id @default(cuid())
  name        String         @unique // SUPER_ADMIN, ADMIN, etc.
  description String?
  isSystem    Boolean        @default(false)
  permissions RolePermission[]
  users       User[]?        // if we want default role? But we have User.role field already; we keep both? We'll use Role for granular permissions.
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([name])
}

model RolePermission {
  id           String       @id @default(cuid())
  roleId       String
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())

  @@unique([roleId, permissionId])
}

model UserPermission {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy    String?      // user who granted
  grantedAt    DateTime     @default(now())
  revokedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
}

model OAuthAccount {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // google, github, etc.
  providerId   String   // unique ID from provider
  email        String
  accessToken  String?  // encrypted
  refreshToken String?  // encrypted
  expiresAt    DateTime?
  tokenType    String?
  scope        String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([provider, providerId])
  @@index([userId])
}

model LoginHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  location    String?
  success     Boolean
  failureReason String?
  deviceId    String?   // could be terminal ID
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

// ==========================================
// MERCHANT SYSTEM
// ==========================================

model Merchant {
  id                     String                 @id @default(cuid())
  name                   String
  legalName              String?
  businessType           String
  registrationNumber     String?                @unique
  taxId                  String?
  email                  String                 @unique
  phone                  String?                @unique
  website                String?
  timezone               String                 @default("UTC")
  currency               CurrencyType           @default(USD)
  status                 MerchantStatus         @default(PENDING)
  description            String?
  logo                   String?                // URL
  contactEmail           String?
  contactPhone           String?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  state                  String?
  postalCode             String?
  country                String?
  isVerified             Boolean                @default(false)
  deletedAt              DateTime?

  // Relations
  users                  User[]
  terminals              Terminal[]
  merchantSettings       MerchantSettings?
  merchantBranding       MerchantBranding?
  merchantSubscription   MerchantSubscription?
  merchantFeatures       MerchantFeature[]
  merchantLimits         MerchantLimits?
  merchantFees           MerchantFee[]
  merchantCompliance     MerchantCompliance?
  merchantDocuments      MerchantDocument[]
  merchantContacts       MerchantContact[]
  merchantAddresses      MerchantAddress[]
  merchantBusinessHours  MerchantBusinessHours[]
  merchantNotificationSettings MerchantNotificationSettings?
  merchantSecuritySettings MerchantSecuritySettings?
  merchantWebhookSettings MerchantWebhookSettings?
  wallets                Wallet[]
  bankAccounts           BankAccount[]
  settlements            Settlement[]
  settlementBatches      SettlementBatch[]
  settlementAttempts     SettlementAttempt[]
  settlementRules        SettlementRule[]
  settlementSchedules    SettlementSchedule[]
  transactions           Transaction[]
  refunds                Refund[]
  chargebacks            Chargeback[]
  disputes               Dispute[]
  paymentIntents         PaymentIntent[]
  paymentAttempts        PaymentAttempt[]
  webhooks               Webhook[]
  webhookDeliveries      WebhookDelivery[]
  webhookEvents          WebhookEvent[]
  kyc                    Kyc?
  kycDocuments           KycDocument[]
  kycReviews             KycReview[]
  identityVerifications  IdentityVerification[]
  addressVerifications   AddressVerification[]
  sanctionChecks         SanctionCheck[]
  pepChecks              PEPCheck[]
  riskAssessments        RiskAssessment[]
  amlChecks              AMLCheck[]
  complianceLogs         ComplianceLog[]
  complianceReviews      ComplianceReview[]
  products               Product[]
  categories             Category[]
  brands                 Brand[]
  inventory              Inventory[]
  inventoryMovements     InventoryMovement[]
  inventoryAdjustments   InventoryAdjustment[]
  suppliers              Supplier[]
  purchases              Purchase[]
  customers              Customer[]
  employees              Employee[]
  departments            Department[]
  reports                Report[]
  reportExports          ReportExport[]
  dashboardWidgets       DashboardWidget[]
  notifications          Notification[]         @relation("MerchantNotification")
  activityLogs           ActivityLog[]          @relation("MerchantActivity")
  auditLogs              AuditLog[]             @relation("MerchantAuditLog")
  systemSettings         SystemSetting[]
  apiKeys                ApiKey[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@index([email])
  @@index([phone])
  @@index([registrationNumber])
  @@index([status])
  @@index([deletedAt])
}

model MerchantSettings {
  id                          String     @id @default(cuid())
  merchantId                  String     @unique
  merchant                    Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  receiptFooter               String?
  receiptLogo                 String?
  autoSettlement              Boolean    @default(true)
  settlementThreshold         Decimal?   @db.Decimal(18, 4)
  defaultCurrency             CurrencyType @default(USD)
  timezone                    String     @default("UTC")
  language                    String     @default("en")
  ipWhitelist                 Json?
  maxTransactionAmount        Decimal?   @db.Decimal(18, 4)
  minTransactionAmount        Decimal?   @db.Decimal(18, 4)
  allowRefunds                Boolean    @default(true)
  allowChargebacks            Boolean    @default(true)
  allowPartialSettlement      Boolean    @default(false)
  settlementAccountId         String?    // reference to BankAccount
  defaultGatewayProviderId    String?    // gateway provider to use
  metadata                    Json?
  createdAt                   DateTime   @default(now())
  updatedAt                   DateTime   @updatedAt
}

model MerchantBranding {
  id             String   @id @default(cuid())
  merchantId     String   @unique
  merchant       Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  companyName    String?
  logo           String?  // URL
  favicon        String?
  primaryColor   String?
  secondaryColor String?
  font           String?
  emailFooter    String?
  receiptHeader  String?
  receiptFooter  String?
  invoiceLogo    String?
  website        String?
  socialLinks    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MerchantSubscription {
  id                 String             @id @default(cuid())
  merchantId         String             @unique
  merchant           Merchant           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan   @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  startDate          DateTime           @default(now())
  expiryDate         DateTime?
  trialEndsAt        DateTime?
  autoRenew          Boolean            @default(false)
  amount             Decimal?           @db.Decimal(18, 4)
  currency           CurrencyType       @default(USD)
  paymentMethod      String?
  lastPaymentDate    DateTime?
  nextPaymentDate    DateTime?
  featureLimits      Json?              // overrides
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([merchantId])
}

model MerchantFeature {
  id                 String       @id @default(cuid())
  merchantId         String
  merchant           Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  featureName        String       // e.g., "MULTI_CURRENCY", "CRYPTO_PAYOUT"
  enabled            Boolean      @default(true)
  config             Json?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([merchantId, featureName])
  @@index([merchantId])
}

model MerchantLimits {
  id                       String     @id @default(cuid())
  merchantId               String     @unique
  merchant                 Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  dailyTransactionLimit    Decimal?   @db.Decimal(18, 4)
  weeklyTransactionLimit   Decimal?   @db.Decimal(18, 4)
  monthlyTransactionLimit  Decimal?   @db.Decimal(18, 4)
  dailyTransactionCount    Int?
  weeklyTransactionCount   Int?
  monthlyTransactionCount  Int?
  perTransactionMax        Decimal?   @db.Decimal(18, 4)
  perTransactionMin        Decimal?   @db.Decimal(18, 4)
  settlementLimit          Decimal?   @db.Decimal(18, 4)
  cryptoConversionLimit    Decimal?   @db.Decimal(18, 4)
  metadata                 Json?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
}

model MerchantFee {
  id               String     @id @default(cuid())
  merchantId       String
  merchant         Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  name             String
  type             String     // percentage, fixed
  amount           Decimal?   @db.Decimal(18, 4)
  rate             Decimal?   @db.Decimal(18, 6) // if percentage
  currency         CurrencyType @default(USD)
  appliesTo        String?    // e.g., "transaction", "settlement", "conversion"
  isActive         Boolean    @default(true)
  metadata         Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([merchantId])
  @@index([isActive])
}

model MerchantCompliance {
  id                   String     @id @default(cuid())
  merchantId           String     @unique
  merchant             Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  riskLevel            RiskLevel  @default(LOW)
  amlStatus            AMLStatus  @default(CLEAR)
  kycStatus            KycStatus  @default(NOT_STARTED)
  lastReviewDate       DateTime?
  nextReviewDate       DateTime?
  pepCheck             Boolean    @default(false)
  sanctionsCheck       Boolean    @default(false)
  restrictedCountries  Json?
  notes                String?
  metadata             Json?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model MerchantDocument {
  id               String     @id @default(cuid())
  merchantId       String
  merchant         Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  type             String     // business_license, id, proof_of_address, etc.
  name             String
  fileUrl          String
  verificationStatus String   // pending, verified, rejected
  rejectionReason  String?
  uploadedAt       DateTime   @default(now())
  verifiedAt       DateTime?
  expiresAt        DateTime?
  metadata         Json?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([merchantId])
}

model MerchantContact {
  id               String     @id @default(cuid())
  merchantId       String
  merchant         Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  email            String
  phone            String?
  role             String?    // primary, support, etc.
  isPrimary        Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([merchantId])
}

model MerchantAddress {
  id               String     @id @default(cuid())
  merchantId       String
  merchant         Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  type             String     // physical, billing, shipping
  addressLine1     String
  addressLine2     String?
  city             String
  state            String?
  postalCode       String?
  country          String
  isDefault        Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([merchantId])
}

model MerchantBusinessHours {
  id               String     @id @default(cuid())
  merchantId       String
  merchant         Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  dayOfWeek        Int        // 0-6
  openTime         String?    // HH:MM
  closeTime        String?    // HH:MM
  isClosed         Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([merchantId, dayOfWeek])
}

model MerchantNotificationSettings {
  id                    String     @id @default(cuid())
  merchantId            String     @unique
  merchant              Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  emailNotifications    Boolean    @default(true)
  smsNotifications      Boolean    @default(false)
  pushNotifications     Boolean    @default(false)
  webhookNotifications  Boolean    @default(false)
  transactionEmails     Boolean    @default(true)
  settlementEmails      Boolean    @default(true)
  securityEmails        Boolean    @default(true)
  promotionalEmails     Boolean    @default(false)
  complianceEmails      Boolean    @default(true)
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model MerchantSecuritySettings {
  id                    String     @id @default(cuid())
  merchantId            String     @unique
  merchant              Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  mfaRequired           Boolean    @default(false)
  passwordPolicy        Json?      // min length, special chars, etc.
  sessionTimeout        Int        @default(3600) // seconds
  ipWhitelistEnabled    Boolean    @default(false)
  ipWhitelist           Json?
  webhookSecret         String?    // encrypted
  apiKeyRotationDays    Int        @default(90)
  auditLogRetentionDays Int        @default(365)
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model MerchantWebhookSettings {
  id                    String     @id @default(cuid())
  merchantId            String     @unique
  merchant              Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  url                   String
  secret                String?    // encrypted
  events                Json       // list of events
  enabled               Boolean    @default(true)
  retryCount            Int        @default(3)
  retryDelay            Int        @default(60)
  timeout               Int        @default(30)
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

// ==========================================
// POS
// ==========================================

model Terminal {
  id                    String           @id @default(cuid())
  merchantId            String
  merchant              Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  serialNumber          String           @unique
  model                 String
  manufacturer          String
  firmwareVersion       String?
  softwareVersion       String?
  status                TerminalStatus   @default(OFFLINE)
  location              String?          // store/outlet
  ipAddress             String?
  macAddress            String?
  lastHeartbeatAt       DateTime?
  lastBootAt            DateTime?
  lastTransactionAt     DateTime?
  batteryLevel          Int?             // percentage
  storageUsed           Int?             // MB
  memoryUsed            Int?             // MB
  terminalGroupId       String?
  terminalGroup         TerminalGroup?   @relation(fields: [terminalGroupId], references: [id], onDelete: SetNull)
  isActive              Boolean          @default(true)
  deletedAt             DateTime?

  // Relations
  terminalConfiguration TerminalConfiguration?
  terminalKeys          TerminalKey[]
  heartbeats            TerminalHeartbeat[]
  terminalLogs          TerminalLog[]
  terminalSoftware      TerminalSoftware[]
  terminalLocations     TerminalLocation[]
  printer               Printer?
  scanner               Scanner?
  cashDrawer            CashDrawer?
  transactions          Transaction[]
  authorization         Authorization?    // if terminal handles auth directly? We'll leave.
  capture               Capture?          // similar
  receipts              ReceiptTemplate[]
  device                Device?           // if terminal is a device
  settlements           Settlement?       // maybe
  session               TerminalSession?  // not defined yet; we can add later
  commands              TerminalCommand?  // not defined yet
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([merchantId])
  @@index([serialNumber])
  @@index([status])
  @@index([terminalGroupId])
  @@index([deletedAt])
}

model TerminalGroup {
  id                    String           @id @default(cuid())
  name                  String
  merchantId            String
  merchant              Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  description           String?
  terminals             Terminal[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([merchantId])
  @@unique([merchantId, name])
}

model TerminalConfiguration {
  id                    String     @id @default(cuid())
  terminalId            String     @unique
  terminal              Terminal   @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  receiptHeader         String?
  receiptFooter         String?
  currency              CurrencyType @default(USD)
  timezone              String     @default("UTC")
  language              String     @default("en")
  printerEnabled        Boolean    @default(true)
  autoPrint             Boolean    @default(true)
  signatureRequired     Boolean    @default(false)
  tipsEnabled           Boolean    @default(false)
  tipPercentages        Json?      // e.g., [10,15,20]
  cashbackEnabled       Boolean    @default(false)
  cashbackLimit         Decimal?   @db.Decimal(18, 4)
  offlineMode           Boolean    @default(false)
  maxOfflineTransactions Int       @default(100)
  settlementSchedule    String?    // e.g., "daily", "manual"
  gatewayOverride       String?    // gateway id
  theme                 String?
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model TerminalKey {
  id                    String     @id @default(cuid())
  terminalId            String
  terminal              Terminal   @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  keyType               String     // api, encryption, signing
  keyHash               String     @unique
  label                 String?
  expiresAt             DateTime?
  lastUsedAt            DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([terminalId])
  @@index([keyHash])
}

model TerminalHeartbeat {
  id                    String     @id @default(cuid())
  terminalId            String
  terminal              Terminal   @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  status                TerminalStatus
  uptime                Int?       // seconds
  battery               Int?
  memoryUsage           Int?
  cpuUsage              Int?
  storageFree           Int?
  networkStatus         String?
  ipAddress             String?
  geolocation           Json?      // lat/lng
  metadata              Json?
  createdAt             DateTime   @default(now())

  @@index([terminalId])
  @@index([createdAt(sort: Desc)])
}

model TerminalLog {
  id                    String     @id @default(cuid())
  terminalId            String
  terminal              Terminal   @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  level                 LogLevel   @default(INFO)
  message               String
  stackTrace            String?
  metadata              Json?
  createdAt             DateTime   @default(now())

  @@index([terminalId])
  @@index([createdAt(sort: Desc)])
  @@index([level])
}

model TerminalSoftware {
  id                    String     @id @default(cuid())
  terminalId            String
  terminal              Terminal   @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  version               String
  releaseNotes          String?
  installedAt           DateTime   @default(now())
  status                String     // installed, pending, failed
  checksum              String?
  fileUrl               String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([terminalId, version])
  @@index([terminalId])
}

model TerminalLocation {
  id                    String     @id @default(cuid())
  terminalId            String
  terminal              Terminal   @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  storeName             String?
  address               String?
  latitude              Decimal?   @db.Decimal(10, 8)
  longitude             Decimal?   @db.Decimal(11, 8)
  city                  String?
  state                 String?
  country               String?
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([terminalId])
}

model Device {
  id                    String     @id @default(cuid())
  terminalId            String?    // optional, if terminal has a device
  terminal              Terminal?  @relation(fields: [terminalId], references: [id], onDelete: SetNull)
  name                  String
  type                  String     // printer, scanner, cash_drawer, etc.
  model                 String?
  serialNumber          String?    @unique
  status                DeviceStatusEnum @default(CONNECTED)
  ipAddress             String?
  port                  Int?
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([terminalId])
  @@index([serialNumber])
}

model Printer {
  id                    String     @id @default(cuid())
  terminalId            String     @unique
  terminal              Terminal   @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  type                  String     // thermal, receipt, label
  paperSize             String?
  characterSet          String?
  autoCut               Boolean    @default(true)
  lineSpacing           Int?
  printSpeed            String?
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
