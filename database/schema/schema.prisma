generator client {
  provider = "prisma-client-js"
  output   = "../../backend/node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/////////////////////////////////////////////////
// ENUMS
/////////////////////////////////////////////////

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
}

enum StoreStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum InventoryMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
  OTHER
}

/////////////////////////////////////////////////
// USERS
/////////////////////////////////////////////////

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         UserRole  @default(CASHIER)

  merchantId   String
  merchant     Merchant  @relation(fields: [merchantId], references: [id])

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

/////////////////////////////////////////////////
// MERCHANTS
/////////////////////////////////////////////////

model Merchant {
  id            String      @id @default(cuid())
  businessName  String
  email         String      @unique
  phone         String?
  address       String?

  users         User[]
  stores        Store[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

/////////////////////////////////////////////////
// STORES
/////////////////////////////////////////////////

model Store {
  id            String       @id @default(cuid())

  name          String
  phone         String?
  address       String?

  status        StoreStatus  @default(ACTIVE)

  merchantId    String
  merchant      Merchant     @relation(fields: [merchantId], references: [id])

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

/////////////////////////////////////////////////
// CATEGORIES
/////////////////////////////////////////////////

model Category {
  id          String      @id @default(cuid())
  name        String
  description String?

  merchantId  String
  merchant    Merchant    @relation(fields: [merchantId], references: [id])

  products    Product[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([merchantId, name])
}

/////////////////////////////////////////////////
// SUPPLIERS
/////////////////////////////////////////////////

model Supplier {
  id          String      @id @default(cuid())

  name        String
  email       String?
  phone       String?
  address     String?

  merchantId  String
  merchant    Merchant    @relation(fields: [merchantId], references: [id])

  purchases   Purchase[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

/////////////////////////////////////////////////
// CUSTOMERS
/////////////////////////////////////////////////

model Customer {
  id          String      @id @default(cuid())

  name        String
  email       String?
  phone       String?
  address     String?

  merchantId  String
  merchant    Merchant    @relation(fields: [merchantId], references: [id])

  sales       Sale[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

/////////////////////////////////////////////////
// PRODUCTS
/////////////////////////////////////////////////

model Product {
  id              String      @id @default(cuid())

  name            String
  sku             String      @unique
  barcode         String?

  description     String?

  costPrice       Decimal     @db.Decimal(12,2)
  sellingPrice    Decimal     @db.Decimal(12,2)

  quantity        Int         @default(0)

  status          ProductStatus @default(ACTIVE)

  merchantId      String
  merchant        Merchant    @relation(fields: [merchantId], references: [id])

  categoryId      String?
  category        Category?   @relation(fields: [categoryId], references: [id])

  inventoryLogs   InventoryMovement[]
  purchaseItems   PurchaseItem[]
  saleItems       SaleItem[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
