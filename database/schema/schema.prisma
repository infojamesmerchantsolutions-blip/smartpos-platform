generator client {
  provider = "prisma-client-js"
  output   = "../../backend/node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/////////////////////////////////////////////////
// ENUMS
/////////////////////////////////////////////////

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
}

enum StoreStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum InventoryMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
  OTHER
}

/////////////////////////////////////////////////
// USERS
/////////////////////////////////////////////////

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         UserRole  @default(CASHIER)

  merchantId   String
  merchant     Merchant  @relation(fields: [merchantId], references: [id])

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

/////////////////////////////////////////////////
// MERCHANTS
/////////////////////////////////////////////////

model Merchant {
  id            String      @id @default(cuid())
  businessName  String
  email         String      @unique
  phone         String?
  address       String?

  users         User[]
  stores        Store[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

/////////////////////////////////////////////////
// STORES
/////////////////////////////////////////////////

model Store {
  id            String       @id @default(cuid())

  name          String
  phone         String?
  address       String?

  status        StoreStatus  @default(ACTIVE)

  merchantId    String
  merchant      Merchant     @relation(fields: [merchantId], references: [id])

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

/////////////////////////////////////////////////
// CATEGORIES
/////////////////////////////////////////////////

model Category {
  id          String      @id @default(cuid())
  name        String
  description String?

  merchantId  String
  merchant    Merchant    @relation(fields: [merchantId], references: [id])

  products    Product[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([merchantId, name])
}

/////////////////////////////////////////////////
// SUPPLIERS
/////////////////////////////////////////////////

model Supplier {
  id          String      @id @default(cuid())

  name        String
  email       String?
  phone       String?
  address     String?

  merchantId  String
  merchant    Merchant    @relation(fields: [merchantId], references: [id])

  purchases   Purchase[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

/////////////////////////////////////////////////
// CUSTOMERS
/////////////////////////////////////////////////

model Customer {
  id          String      @id @default(cuid())

  name        String
  email       String?
  phone       String?
  address     String?

  merchantId  String
  merchant    Merchant    @relation(fields: [merchantId], references: [id])

  sales       Sale[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

/////////////////////////////////////////////////
// PRODUCTS
/////////////////////////////////////////////////

model Product {
  id              String      @id @default(cuid())

  name            String
  sku             String      @unique
  barcode         String?

  description     String?

  costPrice       Decimal     @db.Decimal(12,2)
  sellingPrice    Decimal     @db.Decimal(12,2)

  quantity        Int         @default(0)

  status          ProductStatus @default(ACTIVE)

  merchantId      String
  merchant        Merchant    @relation(fields: [merchantId], references: [id])

  categoryId      String?
  category        Category?   @relation(fields: [categoryId], references: [id])

  inventoryLogs   InventoryMovement[]
  purchaseItems   PurchaseItem[]
  saleItems       SaleItem[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

/////////////////////////////////////////////////
// INVENTORY
/////////////////////////////////////////////////

model InventoryMovement {
  id           String                    @id @default(cuid())

  productId    String
  product      Product                   @relation(fields: [productId], references: [id])

  type         InventoryMovementType

  quantity     Int

  note         String?

  createdById  String?
  createdBy    User?                     @relation(fields: [createdById], references: [id])

  createdAt    DateTime                  @default(now())
}

/////////////////////////////////////////////////
// PURCHASES
/////////////////////////////////////////////////

model Purchase {
  id            String                   @id @default(cuid())

  reference     String                   @unique

  supplierId    String
  supplier      Supplier                 @relation(fields: [supplierId], references: [id])

  merchantId    String
  merchant      Merchant                 @relation(fields: [merchantId], references: [id])

  status        PurchaseStatus           @default(PENDING)

  total         Decimal                  @db.Decimal(12,2)

  items         PurchaseItem[]

  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
}

model PurchaseItem {
  id             String                  @id @default(cuid())

  purchaseId     String
  purchase       Purchase                @relation(fields: [purchaseId], references: [id])

  productId      String
  product        Product                 @relation(fields: [productId], references: [id])

  quantity       Int

  costPrice      Decimal                 @db.Decimal(12,2)

  subtotal       Decimal                 @db.Decimal(12,2)
}

/////////////////////////////////////////////////
// SALES
/////////////////////////////////////////////////

model Sale {
  id              String          @id @default(cuid())

  reference       String          @unique

  merchantId       String
  merchant         Merchant        @relation(fields: [merchantId], references: [id])

  customerId       String?
  customer         Customer?       @relation(fields: [customerId], references: [id])

  cashierId        String
  cashier          User            @relation(fields: [cashierId], references: [id])

  status           SaleStatus      @default(COMPLETED)

  subtotal         Decimal         @db.Decimal(12,2)
  discount         Decimal         @default(0) @db.Decimal(12,2)
  tax              Decimal         @default(0) @db.Decimal(12,2)
  total            Decimal         @db.Decimal(12,2)

  paymentMethod    PaymentMethod

  items            SaleItem[]
  payments         Payment[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model SaleItem {
  id               String          @id @default(cuid())

  saleId           String
  sale             Sale            @relation(fields: [saleId], references: [id])

  productId        String
  product          Product         @relation(fields: [productId], references: [id])

  quantity         Int

  unitPrice        Decimal         @db.Decimal(12,2)

  subtotal         Decimal         @db.Decimal(12,2)
}

/////////////////////////////////////////////////
// PAYMENTS
/////////////////////////////////////////////////

model Payment {
  id               String          @id @default(cuid())

  saleId           String
  sale             Sale            @relation(fields: [saleId], references: [id])

  method           PaymentMethod

  amount           Decimal         @db.Decimal(12,2)

  reference        String?

  createdAt        DateTime        @default(now())
}

/////////////////////////////////////////////////
// EXPENSES
/////////////////////////////////////////////////

model Expense {
  id            String      @id @default(cuid())

  merchantId    String
  merchant      Merchant    @relation(fields: [merchantId], references: [id])

  title         String
  description   String?

  amount        Decimal     @db.Decimal(12,2)

  createdById   String?
  createdBy     User?       @relation(fields: [createdById], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

/////////////////////////////////////////////////
// CASH DRAWERS
/////////////////////////////////////////////////

model CashDrawer {
  id             String      @id @default(cuid())

  merchantId     String
  merchant       Merchant    @relation(fields: [merchantId], references: [id])

  storeId        String
  store          Store       @relation(fields: [storeId], references: [id])

  openingCash    Decimal     @db.Decimal(12,2)
  closingCash    Decimal?    @db.Decimal(12,2)

  openedAt       DateTime    @default(now())
  closedAt       DateTime?

  shifts         Shift[]
}

/////////////////////////////////////////////////
// SHIFTS
/////////////////////////////////////////////////

model Shift {
  id             String       @id @default(cuid())

  cashDrawerId   String
  cashDrawer     CashDrawer   @relation(fields: [cashDrawerId], references: [id])

  userId         String
  user           User         @relation(fields: [userId], references: [id])

  startedAt      DateTime     @default(now())
  endedAt        DateTime?
}
