generator client {
  provider = "prisma-client-js"
  output   = "../../backend/node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/////////////////////////////////////////////////
// ENUMS
/////////////////////////////////////////////////

enum UserRole {
  SUPER_ADMIN
  MERCHANT_ADMIN
  MANAGER
  CASHIER
  SUPPORT
}

enum MerchantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DISABLED
}

enum TerminalStatus {
  PENDING
  ACTIVE
  BLOCKED
  OFFLINE
}

enum WalletType {
  HOT
  COLD
}

enum WalletStatus {
  ACTIVE
  LOCKED
}

enum CurrencyType {
  USD
  NGN
  USDT
  USDC
  BTC
  ETH
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

/////////////////////////////////////////////////
// MERCHANTS
/////////////////////////////////////////////////

model Merchant {
  id            String            @id @default(cuid())

  businessName  String
  email         String            @unique
  phone         String?

  status        MerchantStatus    @default(PENDING)

  users         User[]
  terminals     Terminal[]
  wallets       Wallet[]
  apiKeys       ApiKey[]

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

/////////////////////////////////////////////////
// USERS
/////////////////////////////////////////////////

model User {
  id            String            @id @default(cuid())

  merchantId    String
  merchant      Merchant          @relation(fields: [merchantId], references: [id])

  fullName      String
  email         String            @unique
  passwordHash  String

  role          UserRole

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

/////////////////////////////////////////////////
// POS TERMINALS
/////////////////////////////////////////////////

model Terminal {
  id             String            @id @default(cuid())

  merchantId     String
  merchant       Merchant          @relation(fields: [merchantId], references: [id])

  serialNumber   String            @unique
  deviceId       String            @unique

  name           String

  status         TerminalStatus    @default(PENDING)

  lastSeenAt     DateTime?

  transactions   Transaction[]

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}
